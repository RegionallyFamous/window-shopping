              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/cormorant-garamond-normal-400-latin.woff2"
              ]
            },
            {
              "fontFamily": "Cormorant Garamond",
              "fontStyle": "normal",
              "fontWeight": "500",
              "src": [
                "file:./assets/fonts/cormorant-garamond-normal-500-latin.woff2"
              ]
            },
            {
              "fontFamily": "Cormorant Garamond",
              "fontStyle": "normal",
              "fontWeight": "600",
              "src": [
                "file:./assets/fonts/cormorant-garamond-normal-600-latin.woff2"
              ]
            },
            {
              "fontFamily": "Cormorant Garamond",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": [
                "file:./assets/fonts/cormorant-garamond-normal-700-latin.woff2"
              ]
            }
          ]
        },
        {
          "name": "Mono",
          "slug": "mono",
          "fontFamily": "\"IBM Plex Mono\", \"SF Mono\", Menlo, Consolas, monospace",
          "fontFace": [
            {
              "fontFamily": "IBM Plex Mono",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/ibm-plex-mono-normal-400-latin.woff2"
              ]
            },
            {
              "fontFamily": "IBM Plex Mono",
              "fontStyle": "normal",
              "fontWeight": "500",
              "src": [
                "file:./assets/fonts/ibm-plex-mono-normal-500-latin.woff2"
              ]
            },
            {
              "fontFamily": "IBM Plex Mono",
              "fontStyle": "normal",
              "fontWeight": "600",
              "src": [
                "file:./assets/fonts/ibm-plex-mono-normal-600-latin.woff2"
              ]
            },
            {
              "fontFamily": "IBM Plex Mono",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": [
                "file:./assets/fonts/ibm-plex-mono-normal-700-latin.woff2"
              ]
            }
          ]
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.74rem"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.25rem"
        },
        {
          "name": "XL",
          "slug": "x-large",
          "size": "2rem"
        },
        {
          "name": "XXL",
          "slug": "xx-large",
          "size": "3rem"
        },
        {
          "name": "Display",
          "slug": "display",
          "size": "4.55rem"
        }
      ]
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        {
          "name": "2XS",
          "slug": "20",
          "size": "0.5rem"
        },
        {
          "name": "XS",
          "slug": "30",
          "size": "0.875rem"
        },
        {
          "name": "S",
          "slug": "40",
          "size": "1.25rem"
        },
        {
          "name": "M",
          "slug": "50",
          "size": "2rem"
        },
        {
          "name": "L",
          "slug": "60",
          "size": "3.5rem"
        },
        {
          "name": "XL",
          "slug": "70",
          "size": "6rem"
        }
      ]
    },
    "dimensions": {
      "aspectRatios": [
        {
          "name": "Square",
          "slug": "square",
          "ratio": "1"
        },
        {
          "name": "Catalog",
          "slug": "catalog",
          "ratio": "4/5"
        },
        {
          "name": "Wide",
          "slug": "wide",
          "ratio": "16/9"
        }
      ]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        {
          "name": "Soft",
          "slug": "soft",
          "shadow": "0 28px 80px -56px rgba(25, 22, 18, 0.58)"
        },
        {
          "name": "Crisp",
          "slug": "crisp",
          "shadow": "0 1px 0 rgba(25, 22, 18, 0.12), 0 18px 36px -30px rgba(25, 22, 18, 0.62)"
        },
        {
          "name": "Edge",
          "slug": "edge",
          "shadow": "6px 6px 0 var(--wp--preset--color--contrast)"
        }
      ]
    },
    "custom": {
      "radius": "10px",
      "productImageRatio": "4 / 5",
      "productGridMin": "15rem",
      "borderWeight": "1px",
      "surfaceMix": "92%",
      "buttonRadius": "3px",
      "window": {
        "headerFilter": "blur(18px)",
        "buttonHoverTransform": "translateY(-1px)",
        "surfaceTextColor": "var(--wp--preset--color--contrast)",
        "surfaceMutedColor": "var(--wp--preset--color--muted)",
        "surfaceLinkColor": "var(--wp--preset--color--accent)",
        "surfaceBorderColor": "color-mix(in srgb, var(--wp--preset--color--contrast) 16%, transparent)",
        "surfaceKickerColor": "var(--wp--preset--color--accent)",
        "pageKickerColor": "var(--wp--preset--color--accent)",
        "footerKickerColor": "var(--wp--preset--color--accent)",
        "comingSoonCopyBasis": "43%",
        "comingSoonMediaBasis": "57%",
        "comingSoonHeadingSize": "clamp(2.75rem, 7.5vw, var(--wp--preset--font-size--display))",
        "comingSoonHeadingLineHeight": "1",
        "comingSoonHeadingMaxWidth": "11ch",
        "comingSoonCardMin": "8.5rem",
        "controlBackground": "var(--wp--preset--color--surface)",
        "controlTextColor": "var(--wp--preset--color--contrast)",
        "controlBorderColor": "color-mix(in srgb, var(--wp--preset--color--contrast) 24%, transparent)",
        "checkoutKickerColor": "var(--wp--preset--color--accent)",
        "checkoutRadius": "var(--wp--custom--radius)",
        "checkoutControlRadius": "calc(var(--wp--custom--radius) * 0.75)",
        "checkoutButtonRadius": "var(--wp--custom--button-radius)",
        "checkoutButtonBackground": "var(--wp--preset--color--contrast)",
        "checkoutButtonTextColor": "var(--wp--preset--color--base)",
        "checkoutButtonBorderColor": "var(--wp--preset--color--contrast)",
        "miniCartButtonRadius": "var(--wp--custom--button-radius)",
        "purchaseControlRadius": "calc(var(--wp--custom--radius) * 0.75)",
        "purchaseButtonRadius": "var(--wp--custom--button-radius)",
        "reassuranceGap": "var(--wp--preset--spacing--40)",
        "reassuranceItemMin": "14.5rem",
        "reassuranceItemMinHeight": "5.2rem",
        "reassuranceItemPaddingX": "1.15rem",
        "reassuranceItemPaddingY": "1rem",
        "reassuranceItemRadius": "calc(var(--wp--custom--radius) * 0.75)",
        "reassuranceItemBorder": "1px solid var(--ws-surface-line)",
        "reassuranceItemBackground": "color-mix(in srgb, var(--wp--preset--color--surface) 72%, transparent)",
        "kickerGap": "0.55rem",
        "kickerMarkerSize": "0.55rem",
        "kickerMarkerRadius": "999px",
        "kickerMarkerBackground": "currentColor",
        "heroBackground": "linear-gradient(100deg, var(--wp--preset--color--base), color-mix(in srgb, var(--wp--preset--color--surface) 88%, var(--wp--preset--color--base)))",
        "heroPattern": "linear-gradient(color-mix(in srgb, var(--wp--preset--color--contrast) 5%, transparent) 1px, transparent 1px), linear-gradient(90deg, color-mix(in srgb, var(--wp--preset--color--contrast) 5%, transparent) 1px, transparent 1px)",
        "heroPatternSize": "88px 88px",
        "heroPatternMask": "linear-gradient(90deg, transparent, #000 16%, #000 84%, transparent)",
        "heroPatternOpacity": "0.85",
        "displayBackground": "color-mix(in srgb, var(--wp--preset--color--surface) 76%, transparent)",
        "displayShadowInset": "auto 2rem 1.45rem",
        "displayShadowHeight": "0.65rem",
        "displayShadowRadius": "999px",
        "displayShadowBackground": "color-mix(in srgb, var(--wp--preset--color--contrast) 14%, transparent)",
        "displayShadowFilter": "blur(8px)",
        "productCardPadding": "0.85rem",
        "productCardRadius": "var(--wp--custom--radius)",
        "showcaseCardPadding": "0.58rem",
        "productCardBackground": "color-mix(in srgb, var(--wp--preset--color--surface) 86%, transparent)",
        "productDetailsBackground": "var(--wp--custom--window--product-card-background, var(--ws-surface))",
        "productDetailsTextColor": "var(--ws-surface-text)",
        "productDetailsActiveTextColor": "var(--wp--preset--color--base)",
        "ratingStarColor": "var(--wp--preset--color--accent)",
        "productCardShadow": "none",
        "productCardBorderStyle": "solid",
        "productImageRadius": "var(--wp--custom--radius)",
        "productImageBackground": "var(--ws-soft)",
        "productImageHoverTransform": "scale(1.025)",
        "collectionGap": "var(--wp--preset--spacing--40)",
        "indexCardGap": "0.9rem",
        "showcaseGap": "0.72rem",
        "editorialGap": "clamp(1rem, 2vw, 1.5rem)",
