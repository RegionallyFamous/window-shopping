        "topBarBorderColor": "color-mix(in srgb, var(--wp--preset--color--contrast) 14%, transparent)",
        "headerInnerMinHeight": "3.35rem",
        "headerInnerPaddingY": "0.62rem",
        "heroMinHeight": "min(66vh, 680px)",
        "heroPaddingTop": "var(--wp--preset--spacing--50)",
        "heroPaddingBottom": "var(--wp--preset--spacing--50)",
        "heroColumns": "minmax(0, 0.76fr) minmax(0, 1.24fr)",
        "heroGap": "var(--wp--preset--spacing--50)",
        "heroAlignItems": "stretch",
        "heroCopyBackground": "transparent",
        "heroCopyBorder": "0",
        "heroCopyRadius": "0",
        "heroCopyShadow": "none",
        "heroCopyMinHeight": "26rem",
        "heroCopyPadding": "var(--wp--preset--spacing--50) 0",
        "heroCopyAlignSelf": "center",
        "heroDisplayAlignSelf": "stretch",
        "heroHeadingMaxWidth": "10ch",
        "heroHeadingColor": "var(--wp--preset--color--contrast)",
        "heroTextColor": "var(--wp--preset--color--muted)",
        "heroTextMaxWidth": "31rem",
        "heroKickerColor": "var(--wp--preset--color--muted)",
        "heroOutlineButtonColor": "var(--wp--preset--color--contrast)",
        "heroOutlineButtonBorderColor": "var(--wp--preset--color--contrast)",
        "displayRadius": "12px",
        "displayBorderColor": "color-mix(in srgb, var(--wp--preset--color--contrast) 16%, transparent)",
        "displayBorderStyle": "solid",
        "displayBorderWidth": "1px",
        "displayBoxShadow": "none",
        "displayMinHeight": "25rem",
        "displayPadding": "var(--wp--preset--spacing--30)",
        "displayTextColor": "var(--wp--preset--color--contrast)",
        "displayLabelColor": "var(--wp--preset--color--muted)",
        "showcaseTemplate": "repeat(4, minmax(0, 1fr))",
        "showcaseFirstRow": "auto",
        "showcaseFirstColumn": "auto",
        "showcaseFirstImageRatio": "var(--wp--custom--window--showcase-image-ratio, var(--wp--custom--product-image-ratio))",
        "trustBandBackground": "var(--wp--preset--color--base)",
