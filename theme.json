        "headerTextColor": "var(--wp--preset--color--contrast)",
        "headerLinkColor": "var(--wp--preset--color--contrast)",
        "headerBorderColor": "color-mix(in srgb, var(--wp--preset--color--contrast) 18%, transparent)",
        "topBarDisplay": "none",
