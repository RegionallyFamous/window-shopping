{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1320px"
    },
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "name": "Base",
          "slug": "base",
          "color": "#f2eee7"
        },
        {
          "name": "Surface",
          "slug": "surface",
          "color": "#fffdf8"
        },
        {
          "name": "Contrast",
          "slug": "contrast",
          "color": "#11100e"
        },
        {
          "name": "Muted",
          "slug": "muted",
          "color": "#706960"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#6f5746"
        },
        {
          "name": "Accent 2",
          "slug": "accent-2",
          "color": "#a88b62"
        },
        {
          "name": "Accent 3",
          "slug": "accent-3",
          "color": "#d9d0c0"
        }
      ],
      "gradients": [
        {
          "name": "Soft Storefront",
          "slug": "soft-storefront",
          "gradient": "linear-gradient(135deg, var(--wp--preset--color--surface) 0%, var(--wp--preset--color--base) 62%, color-mix(in srgb, var(--wp--preset--color--accent) 14%, var(--wp--preset--color--base)) 100%)"
        },
        {
          "name": "Accent Wash",
          "slug": "accent-wash",
          "gradient": "linear-gradient(135deg, color-mix(in srgb, var(--wp--preset--color--accent) 18%, var(--wp--preset--color--base)) 0%, color-mix(in srgb, var(--wp--preset--color--accent-2) 14%, var(--wp--preset--color--surface)) 100%)"
        }
      ]
    },
    "typography": {
      "fluid": false,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "name": "Body",
          "slug": "body",
          "fontFamily": "\"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "400",
