        "trustItemTextAlign": "left",
        "trustMarkerSize": "0.55rem",
        "trustMarkerRadius": "999px",
        "trustMarkerBackground": "transparent",
        "trustMarkerBorder": "1px solid currentColor",
        "trustCardBackground": "var(--wp--preset--color--surface)",
        "trustCardBorder": "1px solid color-mix(in srgb, var(--wp--preset--color--contrast) 12%, transparent)",
        "trustCardRadius": "10px",
        "trustCardPaddingX": "clamp(0.85rem, 1.4vw, 1.2rem)",
        "trustCardPaddingY": "0.86rem",
        "trustCardMinHeight": "4.85rem",
        "trustTitleColor": "var(--wp--preset--color--contrast)",
        "trustSubcopyColor": "var(--wp--preset--color--muted)",
        "trustIconShellSize": "2.45rem",
        "trustIconShellRadius": "999px",
        "trustIconShellBackground": "color-mix(in srgb, var(--wp--preset--color--accent-2) 22%, transparent)",
        "trustIconShellBorder": "1px solid color-mix(in srgb, var(--wp--preset--color--contrast) 10%, transparent)",
        "trustIconColor": "var(--wp--preset--color--accent)",
        "trustIconSize": "1.16rem",
        "trustIconStrokeWidth": "1.75",
        "showcaseCardMinHeight": "16.5rem",
        "showcaseImageRatio": "4 / 5",
        "showcaseImageRadius": "calc(var(--wp--custom--radius) * 0.72)",
        "showcaseTitleMarginTop": "0.72rem",
        "showcaseTitleMarginBottom": "0.25rem",
        "showcaseTitleFontSize": "0.76rem",
        "showcaseTitleLineHeight": "1.16",
        "showcaseTitleColor": "var(--wp--preset--color--contrast)",
        "showcasePriceColor": "var(--wp--preset--color--contrast)",
        "showcasePriceFontSize": "0.7rem",
        "showcasePriceMarginBottom": "0.75rem",
        "showcaseButtonSize": "1.85rem",
        "showcaseButtonRadius": "999px",
        "showcaseButtonBorder": "1px solid currentColor",
        "showcaseButtonBackground": "var(--wp--preset--color--surface)",
        "showcaseButtonColor": "var(--wp--preset--color--muted)",
        "showcaseButtonShadow": "none",
        "showcaseButtonSymbolSize": "0.95rem",
        "showcaseCardTilt": "0deg",
        "showcaseCardTilt1": "0deg",
        "showcaseCardTilt2": "0deg",
        "showcaseCardTilt3": "0deg",
        "heroAccentDisplay": "block",
        "heroAccentTop": "auto",
        "heroAccentRight": "18%",
        "heroAccentBottom": "13%",
        "heroAccentLeft": "auto",
        "heroAccentWidth": "13rem",
        "heroAccentHeight": "13rem",
        "heroAccentBorder": "0",
        "heroAccentRadius": "999px",
        "heroAccentBackground": "radial-gradient(circle, color-mix(in srgb, var(--wp--preset--color--accent) 16%, transparent) 0 42%, transparent 43%)",
        "heroAccentShadow": "none",
        "heroAccentOpacity": "0.72",
        "heroAccentTransform": "none",
        "heroAreas": "'copy display'",
        "heroCopyJustifySelf": "stretch",
        "heroCopyWidth": "auto",
        "heroCopyMaxWidth": "none",
        "heroDisplayJustifySelf": "stretch",
        "heroDisplayWidth": "auto",
        "heroDisplayMaxWidth": "none",
        "headerActionBackground": "transparent",
        "headerActionColor": "var(--wp--preset--color--contrast)",
        "headerActionBorderColor": "transparent",
        "headerActionSize": "44px",
        "headerActionRadius": "var(--wp--custom--button-radius)",
        "headerActionPaddingX": "0.85rem",
        "headerActionsGap": "0.58rem",
        "brandMaxWidth": "5.1rem",
        "brandFontSize": "0.88rem",
        "brandLineHeight": "0.92",
        "brandTextTransform": "uppercase",
        "navFontSize": "0.78rem",
        "navFontWeight": "700",
        "navTextTransform": "none",
        "indexTitleColor": "currentColor",
        "indexPriceColor": "currentColor",
        "indexImageRatio": "var(--wp--custom--product-image-ratio)",
        "indexButtonRadius": "var(--wp--custom--button-radius)",
        "indexButtonBorder": "1px solid color-mix(in srgb, var(--wp--preset--color--contrast) 72%, transparent)",
        "indexButtonBackground": "transparent",
        "indexButtonColor": "var(--wp--preset--color--contrast)"
      }
