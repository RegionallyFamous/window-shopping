  },
  "styles": {
    "color": {
      "background": "var:preset|color|base",
      "text": "var:preset|color|contrast"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|40",
      "padding": {
        "right": "var:preset|spacing|50",
        "left": "var:preset|spacing|50"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "var:preset|font-size|medium",
      "fontWeight": "430",
      "lineHeight": "1.55"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "var(--wp--custom--button-radius)"
        },
        "color": {
          "background": "var:preset|color|contrast",
          "text": "var:preset|color|base"
        },
        "spacing": {
          "padding": {
            "top": "0.85rem",
            "right": "1.25rem",
            "bottom": "0.85rem",
            "left": "1.25rem"
          }
        },
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "760",
          "letterSpacing": "0",
          "textDecoration": "none"
        }
      },
      "heading": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "500",
          "letterSpacing": "0",
          "lineHeight": "1.05"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "textDecoration": "underline"
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontSize": "0.78rem",
          "fontWeight": "680",
          "textTransform": "none"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontWeight": "850",
          "letterSpacing": "0",
          "lineHeight": "1",
          "fontSize": "1.05rem",
          "textTransform": "none"
        },
        "color": {
          "text": "var:preset|color|contrast"
        }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large",
          "fontWeight": "500"
        }
      },
      "core/query-title": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large",
          "fontWeight": "500"
        }
      },
      "core/separator": {
        "color": {
          "text": "color-mix(in srgb, var(--wp--preset--color--contrast) 18%, transparent)"
        }
      },
      "woocommerce/product-button": {
        "typography": {
          "fontWeight": "760"
        }
      },
      "woocommerce/product-price": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "700"
        }
      },
      "woocommerce/breadcrumbs": {
        "color": {
          "text": "var:preset|color|muted"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small"
        }
      },
      "woocommerce/product-meta": {
        "color": {
          "text": "var:preset|color|muted"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small"
        }
      },
      "woocommerce/product-rating": {
        "color": {
          "text": "var:preset|color|accent-2"
        }
      }
    }
  },
  "templateParts": [
