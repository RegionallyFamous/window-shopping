        "kickerGap": "0.65rem",
        "kickerMarkerSize": "1rem",
        "kickerMarkerRadius": "0",
        "kickerMarkerBackground": "var(--wp--preset--color--accent-2)",
        "heroBackground": "linear-gradient(90deg, var(--wp--preset--color--base) 0 41%, var(--wp--preset--color--surface) 41% 100%)",
        "heroPattern": "linear-gradient(color-mix(in srgb, var(--wp--preset--color--contrast) 10%, transparent) 1px, transparent 1px)",
        "heroPatternSize": "100% 7rem",
        "heroPatternMask": "linear-gradient(90deg, #000 0 41%, transparent 41% 100%)",
        "heroPatternOpacity": "0.32",
        "displayBackground": "var(--wp--preset--color--surface)",
        "displayShadowInset": "auto 0 0",
        "displayShadowHeight": "1px",
        "displayShadowRadius": "0",
        "displayShadowBackground": "var(--wp--preset--color--base)",
        "displayShadowFilter": "none",
        "productCardPadding": "0",
        "productCardRadius": "0px",
        "showcaseCardPadding": "0",
        "productCardBackground": "transparent",
        "productDetailsBackground": "var(--wp--preset--color--base)",
        "productDetailsTextColor": "var(--wp--preset--color--contrast)",
        "productDetailsActiveTextColor": "var(--wp--preset--color--base)",
        "productCardShadow": "none",
        "productCardBorderStyle": "solid",
        "productImageRadius": "0",
        "productImageBackground": "var(--wp--preset--color--surface)",
        "productImageHoverTransform": "scale(1.018)",
        "collectionGap": "1.1rem",
        "indexCardGap": "1px",
        "showcaseGap": "1px",
        "editorialGap": "var(--wp--preset--spacing--50)",
        "showcaseCardShadow": "none",
        "headerBackground": "var(--wp--preset--color--base)",
        "headerTextColor": "var(--wp--preset--color--contrast)",
        "headerLinkColor": "var(--wp--preset--color--contrast)",
        "headerBorderColor": "color-mix(in srgb, var(--wp--preset--color--contrast) 24%, transparent)",
        "topBarDisplay": "none",
        "topBarMinHeight": "2.05rem",
        "topBarBackground": "transparent",
        "topBarTextColor": "var(--wp--preset--color--muted)",
        "topBarBorderColor": "color-mix(in srgb, var(--wp--preset--color--contrast) 14%, transparent)",
        "headerInnerMinHeight": "4rem",
        "headerInnerPaddingY": "0.5rem",
        "heroMinHeight": "calc(100vh - 10.05rem)",
        "heroPaddingTop": "1rem",
        "heroPaddingBottom": "var(--wp--preset--spacing--30)",
        "heroColumns": "minmax(0, 0.7fr) minmax(0, 1.3fr)",
        "heroGap": "0",
        "heroAlignItems": "stretch",
        "heroCopyBackground": "var(--wp--preset--color--base)",
        "heroCopyBorder": "0",
        "heroCopyRadius": "0",
        "heroCopyShadow": "none",
        "heroCopyMinHeight": "26.4rem",
        "heroCopyPadding": "var(--wp--preset--spacing--40) var(--wp--preset--spacing--50)",
        "heroCopyAlignSelf": "center",
        "heroDisplayAlignSelf": "stretch",
        "heroHeadingMaxWidth": "9.6ch",
        "heroHeadingColor": "var(--wp--preset--color--contrast)",
        "heroTextColor": "color-mix(in srgb, var(--wp--preset--color--contrast) 72%, transparent)",
        "heroTextMaxWidth": "20rem",
        "heroKickerColor": "var(--wp--preset--color--accent-2)",
        "heroOutlineButtonColor": "var(--wp--preset--color--contrast)",
        "heroOutlineButtonBorderColor": "var(--wp--preset--color--accent-2)",
        "displayRadius": "0",
        "displayBorderColor": "transparent",
        "displayBorderStyle": "solid",
        "displayBorderWidth": "0",
        "displayBoxShadow": "none",
        "displayMinHeight": "25.8rem",
        "displayPadding": "0.72rem 0 0.72rem 0.72rem",
        "displayTextColor": "#171412",
        "displayLabelColor": "#171412",
        "showcaseTemplate": "repeat(4, minmax(0, 1fr))",
        "showcaseFirstRow": "auto",
        "showcaseFirstColumn": "auto",
        "showcaseFirstImageRatio": "var(--wp--custom--window--showcase-image-ratio, var(--wp--custom--product-image-ratio))",
        "trustBandBackground": "var(--wp--preset--color--surface)",
        "trustBandTextColor": "#514a40",
        "trustBandBorderColor": "color-mix(in srgb, #171412 20%, transparent)",
        "trustBandPaddingY": "0.95rem",
        "trustBandGap": "0.75rem",
        "trustItemJustify": "center",
        "trustItemTextAlign": "left",
        "trustMarkerSize": "1.05rem",
        "trustMarkerRadius": "0",
        "trustMarkerBackground": "currentColor",
        "trustMarkerBorder": "0",
        "trustCardBackground": "color-mix(in srgb, var(--wp--preset--color--surface) 92%, #171412)",
        "trustCardBorder": "1px solid color-mix(in srgb, #171412 22%, transparent)",
        "trustCardRadius": "0",
        "trustCardPaddingX": "clamp(0.9rem, 1.45vw, 1.2rem)",
        "trustCardPaddingY": "0.9rem",
        "trustCardMinHeight": "4.85rem",
        "trustTitleColor": "#171412",
        "trustSubcopyColor": "#6d6253",
        "trustIconShellSize": "2.45rem",
        "trustIconShellRadius": "0",
        "trustIconShellBackground": "#171412",
        "trustIconShellBorder": "1px solid #171412",
        "trustIconColor": "var(--wp--preset--color--surface)",
        "showcaseCardMinHeight": "18.7rem",
        "showcaseImageRatio": "3 / 4",
        "showcaseImageRadius": "0",
        "showcaseTitleMarginTop": "0.54rem",
        "showcaseTitleMarginBottom": "0.2rem",
        "showcaseTitleFontSize": "0.66rem",
        "showcaseTitleLineHeight": "1.16",
        "showcaseTitleColor": "#171412",
        "showcasePriceColor": "#171412",
        "showcasePriceFontSize": "0.62rem",
        "showcasePriceMarginBottom": "0.58rem",
        "showcaseButtonSize": "1.55rem",
        "showcaseButtonRadius": "999px",
        "showcaseButtonBorder": "1px solid #171412",
        "showcaseButtonBackground": "#171412",
        "showcaseButtonColor": "var(--wp--preset--color--surface)",
        "showcaseButtonShadow": "none",
        "showcaseButtonSymbolSize": "0.9rem",
        "showcaseCardTilt": "0deg",
        "showcaseCardTilt1": "0deg",
        "showcaseCardTilt2": "0deg",
        "showcaseCardTilt3": "0deg",
        "heroAccentDisplay": "block",
        "heroAccentTop": "auto",
        "heroAccentRight": "auto",
        "heroAccentBottom": "4.2rem",
        "heroAccentLeft": "3.4rem",
        "heroAccentWidth": "12rem",
        "heroAccentHeight": "1px",
        "heroAccentBorder": "0",
        "heroAccentRadius": "0",
        "heroAccentBackground": "color-mix(in srgb, var(--wp--preset--color--contrast) 34%, transparent)",
        "heroAccentShadow": "none",
        "heroAccentOpacity": "1",
        "heroAccentTransform": "none",
        "heroAreas": "'copy display'",
        "heroCopyJustifySelf": "stretch",
        "heroCopyWidth": "auto",
        "heroCopyMaxWidth": "none",
        "heroDisplayJustifySelf": "stretch",
        "heroDisplayWidth": "auto",
        "heroDisplayMaxWidth": "none",
        "headerActionBackground": "transparent",
        "headerActionColor": "var(--wp--preset--color--contrast)",
        "headerActionBorderColor": "transparent",
        "headerActionSize": "42px",
        "headerActionRadius": "0px",
        "headerActionPaddingX": "0.75rem",
        "headerActionsGap": "0.42rem",
        "brandMaxWidth": "5.2rem",
        "brandFontSize": "0.82rem",
        "brandLineHeight": "0.9",
        "brandTextTransform": "uppercase",
        "headerInnerGap": "var(--wp--preset--spacing--40)",
        "headerGridColumns": "minmax(10rem, 1fr) auto minmax(10rem, 1fr)",
        "headerIconSize": "21px",
        "productCardBorderColor": "color-mix(in srgb, #171412 22%, transparent)",
        "indexTitleColor": "currentColor",
        "indexPriceColor": "currentColor",
        "indexButtonRadius": "0px",
        "indexButtonBorder": "1px solid currentColor",
        "indexButtonBackground": "transparent",
        "indexButtonColor": "currentColor",
        "trustBandMarginTop": "0",
        "trustItemGap": "0.75rem",
        "trustIconSize": "1.1rem",
        "trustIconStrokeWidth": "1.45",
        "navFontSize": "0.66rem",
        "navFontWeight": "520",
        "navTextTransform": "none",
        "heroHeadingMarginTop": "0.66rem",
        "heroHeadingMarginBottom": "0.72rem",
        "heroTextMarginBottom": "0.86rem",
        "heroButtonGap": "0.55rem",
        "displayLabelGap": "0.58rem",
        "mobileDisplayPadding": "0.65rem",
        "mobileHeroGap": "var(--wp--preset--spacing--30)",
        "mobileShowcaseGap": "1px",
        "mobileShowcaseCardPadding": "0",
        "mobileShowcaseCardMinHeight": "0",
        "mobileTrustBandGap": "var(--wp--preset--spacing--30)",
        "mobileHeroBackground": "linear-gradient(180deg, var(--wp--preset--color--base) 0 44%, var(--wp--preset--color--surface) 44% 100%)"
      }
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|base",
      "text": "var:preset|color|contrast"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|40",
      "padding": {
        "right": "var:preset|spacing|50",
        "left": "var:preset|spacing|50"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "var:preset|font-size|medium",
      "fontWeight": "430",
      "lineHeight": "1.52",
      "letterSpacing": "0"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "var(--wp--custom--button-radius)",
          "width": "0"
        },
        "color": {
          "background": "var:preset|color|contrast",
          "text": "var:preset|color|base"
        },
        "spacing": {
          "padding": {
            "top": "0.82rem",
            "right": "1.18rem",
            "bottom": "0.82rem",
            "left": "1.18rem"
          }
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "0.66rem",
          "fontWeight": "760",
          "letterSpacing": "0",
          "textDecoration": "none",
          "textTransform": "uppercase"
        }
      },
      "heading": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "500",
          "letterSpacing": "0",
          "lineHeight": "0.98"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|accent"
        },
        "typography": {
          "textDecoration": "none"
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "0.68rem",
          "fontWeight": "650",
          "textTransform": "none",
          "letterSpacing": "0"
        },
        "color": {
          "text": "var:preset|color|contrast"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontSize": "0.82rem",
          "fontWeight": "850",
          "letterSpacing": "0",
          "lineHeight": "1",
          "textTransform": "uppercase"
        },
        "color": {
          "text": "var:preset|color|contrast"
        }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large",
          "lineHeight": "0.98",
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "500"
        }
      },
      "core/query-title": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large",
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "500",
          "lineHeight": "0.98"
        }
      },
      "core/quote": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|large",
          "lineHeight": "1.25"
        }
      },
      "woocommerce/product-price": {
        "color": {
          "text": "#171412"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "760",
          "textTransform": "uppercase",
          "letterSpacing": "0"
        }
      },
      "woocommerce/product-button": {
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontWeight": "800",
          "textTransform": "uppercase",
          "letterSpacing": "0"
        },
        "border": {
          "radius": "var(--wp--custom--button-radius)"
        },
        "color": {
          "background": "var:preset|color|contrast",
          "text": "var:preset|color|base"
        }
      },
      "woocommerce/breadcrumbs": {
        "color": {
          "text": "var:preset|color|muted"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "650",
          "textTransform": "uppercase"
        }
      },
      "woocommerce/product-meta": {
        "color": {
          "text": "var:preset|color|muted"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small"
        }
      },
      "woocommerce/product-rating": {
        "color": {
          "text": "var:preset|color|accent-2"
        }
      }
    }
  }
}
