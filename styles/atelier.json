      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.66rem"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.15rem"
        },
        {
          "name": "XL",
          "slug": "x-large",
          "size": "2rem"
        },
        {
          "name": "XXL",
          "slug": "xx-large",
          "size": "3rem"
        },
        {
          "name": "Display",
          "slug": "display",
          "size": "4.65rem"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "name": "2XS",
          "slug": "20",
          "size": "0.375rem"
        },
        {
          "name": "XS",
          "slug": "30",
          "size": "0.75rem"
        },
        {
          "name": "S",
          "slug": "40",
          "size": "1.125rem"
        },
        {
          "name": "M",
          "slug": "50",
          "size": "1.875rem"
        },
        {
          "name": "L",
          "slug": "60",
          "size": "3.2rem"
        },
        {
          "name": "XL",
          "slug": "70",
          "size": "5.5rem"
        }
      ]
    },
    "shadow": {
      "presets": [
        {
          "name": "Soft",
          "slug": "soft",
          "shadow": "0 48px 120px -86px rgba(12, 12, 15, 0.7)"
        },
        {
          "name": "Crisp",
          "slug": "crisp",
          "shadow": "0 1px 0 rgba(12, 12, 15, 0.18)"
        },
        {
          "name": "Edge",
          "slug": "edge",
          "shadow": "0 0 0 1px #0c0c0f"
        }
      ]
    },
    "custom": {
      "radius": "0px",
      "productImageRatio": "3 / 4",
      "productGridMin": "14rem",
      "borderWeight": "1px",
      "surfaceMix": "100%",
      "buttonRadius": "0px",
      "window": {
        "headerFilter": "none",
        "buttonHoverTransform": "translateY(-1px)",
        "surfaceTextColor": "#171412",
        "surfaceMutedColor": "#5e574c",
        "surfaceLinkColor": "var(--wp--preset--color--accent)",
        "surfaceBorderColor": "color-mix(in srgb, #171412 24%, transparent)",
        "surfaceKickerColor": "var(--wp--preset--color--accent)",
        "pageKickerColor": "var(--wp--preset--color--accent)",
        "controlBackground": "#fffaf0",
        "controlTextColor": "#171412",
        "controlBorderColor": "color-mix(in srgb, #171412 36%, transparent)",
        "checkoutKickerColor": "var(--wp--preset--color--accent)",
        "checkoutRadius": "0px",
        "checkoutControlRadius": "0px",
        "checkoutButtonRadius": "0px",
        "miniCartButtonRadius": "0px",
        "purchaseControlRadius": "0px",
        "purchaseButtonRadius": "0px",
        "reassuranceGap": "1px",
        "reassuranceItemMin": "12rem",
        "reassuranceItemMinHeight": "4.35rem",
        "reassuranceItemPaddingX": "0.95rem",
        "reassuranceItemPaddingY": "0.78rem",
