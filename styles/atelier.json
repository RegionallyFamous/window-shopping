{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Atelier",
  "settings": {
    "layout": {
      "contentSize": "720px",
      "wideSize": "1480px"
    },
    "color": {
      "palette": [
        {
          "name": "Base",
          "slug": "base",
          "color": "#0f0f0e"
        },
        {
          "name": "Surface",
          "slug": "surface",
          "color": "#f4eee2"
        },
        {
          "name": "Contrast",
          "slug": "contrast",
          "color": "#f4eee2"
        },
        {
          "name": "Muted",
          "slug": "muted",
          "color": "#b8ac98"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#ba8d2d"
        },
        {
          "name": "Accent 2",
          "slug": "accent-2",
          "color": "#d8bc77"
        },
        {
          "name": "Accent 3",
          "slug": "accent-3",
          "color": "#262320"
        }
      ],
      "gradients": [
        {
          "name": "Editorial Fold",
          "slug": "soft-storefront",
          "gradient": "linear-gradient(90deg, #fffdf8 0%, #f3eee6 42%, #e3d4c3 100%)"
        },
        {
          "name": "Runway Mark",
          "slug": "accent-wash",
          "gradient": "linear-gradient(135deg, #0c0c0f 0%, #7d1f36 56%, #b69154 100%)"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Body",
          "slug": "body",
          "fontFamily": "\"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/inter-normal-400-latin.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "500",
              "src": [
                "file:./assets/fonts/inter-normal-500-latin.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "600",
              "src": [
                "file:./assets/fonts/inter-normal-600-latin.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": [
                "file:./assets/fonts/inter-normal-700-latin.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "800",
              "src": [
                "file:./assets/fonts/inter-normal-800-latin.woff2"
