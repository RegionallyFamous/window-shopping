  "styles": {
    "color": {
      "background": "var:preset|color|base",
      "text": "var:preset|color|contrast"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|40",
      "padding": {
        "right": "var:preset|spacing|50",
        "left": "var:preset|spacing|50"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "var:preset|font-size|medium",
      "fontWeight": "520",
      "lineHeight": "1.52",
      "letterSpacing": "0"
    },
    "elements": {
      "button": {
        "border": {
          "color": "var:preset|color|contrast",
          "radius": "var(--wp--custom--button-radius)",
          "style": "solid",
          "width": "0"
        },
        "color": {
          "background": "var:preset|color|accent",
          "text": "var:preset|color|surface"
        },
        "spacing": {
          "padding": {
            "top": "0.82rem",
            "right": "1.18rem",
            "bottom": "0.82rem",
            "left": "1.18rem"
          }
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "0.72rem",
          "fontWeight": "820",
          "letterSpacing": "0",
          "textDecoration": "none",
          "textTransform": "uppercase"
        }
      },
      "heading": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontStyle": "normal",
          "fontWeight": "400",
          "letterSpacing": "0",
          "lineHeight": "0.88"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|accent"
        },
        "typography": {
          "textDecoration": "none"
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "0.72rem",
          "fontWeight": "760",
          "textTransform": "none",
          "letterSpacing": "0"
        },
        "color": {
          "text": "var:preset|color|contrast"
        }
      },
      "core/site-title": {
        "color": {
          "text": "var:preset|color|accent-2"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontWeight": "900",
          "letterSpacing": "0",
          "lineHeight": "1",
          "fontSize": "0.86rem",
          "textTransform": "uppercase"
        }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large",
          "fontStyle": "italic",
          "lineHeight": "0.9",
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "400"
        }
      },
      "core/query-title": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large",
          "fontStyle": "italic",
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "400",
          "lineHeight": "0.9"
        }
      },
      "core/quote": {
        "typography": {
          "fontStyle": "italic",
          "fontWeight": "650"
        }
      },
      "woocommerce/product-price": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "760",
          "letterSpacing": "0"
        }
      },
      "woocommerce/product-button": {
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontWeight": "800",
          "textTransform": "uppercase",
          "letterSpacing": "0"
        },
        "border": {
          "radius": "var(--wp--custom--button-radius)"
        },
        "color": {
          "background": "var:preset|color|accent",
          "text": "var:preset|color|surface"
        }
      },
      "woocommerce/breadcrumbs": {
        "color": {
          "text": "var:preset|color|muted"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "800",
          "textTransform": "uppercase"
        }
      },
      "woocommerce/product-meta": {
        "color": {
          "text": "var:preset|color|muted"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "var:preset|font-size|small"
        }
      },
      "woocommerce/product-rating": {
        "color": {
          "text": "var:preset|color|accent-2"
        }
      }
    }
  }
}
