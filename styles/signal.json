  "styles": {
    "color": {
      "background": "var:preset|color|base",
      "text": "var:preset|color|contrast"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|40",
      "padding": {
        "right": "var:preset|spacing|50",
        "left": "var:preset|spacing|50"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "var:preset|font-size|medium",
      "fontWeight": "450",
      "lineHeight": "1.52"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "var(--wp--custom--button-radius)",
          "width": "0"
        },
        "color": {
          "background": "var:preset|color|accent",
          "text": "var:preset|color|base"
        },
        "shadow": "var(--wp--custom--signal-glow)",
        "spacing": {
          "padding": {
            "top": "0.9rem",
            "right": "1.35rem",
            "bottom": "0.9rem",
            "left": "1.35rem"
          }
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "0.78rem",
          "fontWeight": "780",
          "letterSpacing": "0",
          "textDecoration": "none",
          "textTransform": "uppercase"
        }
      },
      "caption": {
        "color": {
          "text": "var:preset|color|muted"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "lineHeight": "1.45"
        }
      },
      "heading": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "700",
          "letterSpacing": "0",
          "lineHeight": "1.02"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|accent"
        },
        "typography": {
          "textDecoration": "none"
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "0.78rem",
          "fontWeight": "720",
          "letterSpacing": "0",
          "textTransform": "none"
        }
      },
      "core/site-title": {
        "color": {
          "text": "var:preset|color|accent"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontWeight": "850",
          "letterSpacing": "0",
          "lineHeight": "1",
          "fontSize": "1rem",
          "textTransform": "uppercase"
        }
      },
      "core/post-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|xx-large",
          "fontWeight": "700",
          "lineHeight": "1.02"
        }
      },
      "core/query-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|xx-large",
          "fontWeight": "700",
          "lineHeight": "1.02"
        }
      },
      "core/separator": {
        "color": {
          "text": "var(--wp--custom--signal-line)"
        }
      },
      "woocommerce/product-price": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "780",
          "letterSpacing": "0"
        }
      },
      "woocommerce/product-button": {
        "border": {
          "radius": "var(--wp--custom--button-radius)"
        },
        "color": {
          "background": "var:preset|color|contrast",
          "text": "var:preset|color|surface"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontWeight": "800",
          "letterSpacing": "0"
        }
      },
      "woocommerce/breadcrumbs": {
        "color": {
          "text": "var:preset|color|muted"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "620",
          "letterSpacing": "0"
        }
      },
      "woocommerce/product-meta": {
        "color": {
          "text": "var:preset|color|muted"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "560",
          "letterSpacing": "0",
          "lineHeight": "1.55"
        }
      },
      "woocommerce/product-rating": {
