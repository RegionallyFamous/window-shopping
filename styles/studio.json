  "styles": {
    "color": {
      "background": "var:preset|color|base",
      "text": "var:preset|color|contrast"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|40",
      "padding": {
        "right": "var:preset|spacing|50",
        "left": "var:preset|spacing|50"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "var:preset|font-size|medium",
      "fontWeight": "430",
      "lineHeight": "1.52",
      "letterSpacing": "0"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "var(--wp--custom--button-radius)",
          "width": "0"
        },
        "color": {
          "background": "var:preset|color|contrast",
          "text": "var:preset|color|surface"
        },
        "spacing": {
          "padding": {
            "top": "0.82rem",
            "right": "1.18rem",
            "bottom": "0.82rem",
            "left": "1.18rem"
          }
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "0.74rem",
          "fontWeight": "760",
          "letterSpacing": "0",
          "textDecoration": "none",
          "textTransform": "uppercase"
        }
      },
      "heading": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "500",
          "letterSpacing": "0",
          "lineHeight": "1"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|accent"
        },
        "typography": {
          "textDecoration": "none"
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "0.74rem",
          "fontWeight": "650",
          "textTransform": "none",
          "letterSpacing": "0"
        },
        "color": {
          "text": "var:preset|color|contrast"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "500",
          "letterSpacing": "0",
          "lineHeight": "1",
          "fontSize": "1.45rem",
          "textTransform": "uppercase"
        },
        "color": {
          "text": "var:preset|color|contrast"
        }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large",
          "lineHeight": "1",
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "500"
        }
      },
      "core/query-title": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large",
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "500",
          "lineHeight": "1"
        }
      },
      "woocommerce/product-price": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|mono",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "760",
          "letterSpacing": "0"
        }
      },
      "woocommerce/product-button": {
        "typography": {
          "fontWeight": "800",
          "fontFamily": "var:preset|font-family|mono",
          "letterSpacing": "0",
          "textTransform": "uppercase"
        },
        "border": {
          "radius": "var(--wp--custom--button-radius)"
        },
        "color": {
          "background": "var:preset|color|contrast",
          "text": "var:preset|color|surface"
        }
      },
      "woocommerce/breadcrumbs": {
        "color": {
          "text": "var:preset|color|muted"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small"
        }
      },
      "woocommerce/product-meta": {
        "color": {
